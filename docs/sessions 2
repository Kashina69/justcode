      "content": "import { api } from \"@/utils/api\";\nimport { useEffect, useState, useCallback } from \"react\";\nimport { DEFAULT_METRICS } from \"@/app/dashboard/dashboard.constents\";\n\ninterface AgenciesMetricResponse {\n    data: {\n        value: string;\n        change: string;\n        isPositive: boolean;\n        sparklineData: number[];\n    };\n}\n\ninterface GenericMetricResponse {\n    data: {\n        currentValue: number;\n        percentageChange: number;\n        sparklineData: number[];\n    };\n}\n\nexport interface MetricItem {\n    title: string;\n    value: string;\n    change: string;\n    isPositive: boolean;\n    sparklineData: number[];\n    isLoading: boolean;\n}\n\nexport interface DashboardFilters {\n    dateRange: \"all\" | \"7d\" | \"30d\" | \"90d\";\n    subType: \"all\" | string;\n    agencyStatus: \"all\" | \"active\" | \"pending\";\n}\n\nexport default function useDashboardMetrics(\n    filters: DashboardFilters = {\n        dateRange: \"all\",\n        subType: \"all\",\n        agencyStatus: \"all\",\n    }\n) {\n    // 1. Initialize state with DEFAULT_METRICS to avoid undefined glitches\n    const [dashboardMetrics, setDashboardMetrics] = useState<MetricItem[]>(DEFAULT_METRICS);\n    // 2. Safely populate elements inside the state updater\n    const updateMetric = useCallback((index: number, updatedFields: Partial<MetricItem>) => {\n        setDashboardMetrics((prev) =>\n            (prev || []).map((metric, i) =>\n                i === index\n                    ? {\n                          ...metric,\n                          ...updatedFields,\n                      }\n                    : metric\n            )\n        );\n    }, []);\n\n    const fetchAgencies = async (params: Record<string, string>) => {\n        try {\n            updateMetric(0, { isLoading: true });\n            const res = await api<AgenciesMetricResponse>(\"/dashboard/agencies\", {\n                method: \"GET\",\n                params,\n            });\n            if (res.data) {\n                updateMetric(0, {\n                    title: \"Registered Agencies\",\n                    value: res.data.value,\n                    change: res.data.change,\n                    isPositive: res.data.isPositive,\n                    sparklineData: res.data.sparklineData,\n                    isLoading: false,\n                });\n            }\n        } catch (error) {\n            console.error(\"Failed to fetch agencies:\", error);\n            updateMetric(1, {\n                value: \"N/A\",\n                change: \"0%\",\n                isPositive: false,\n                sparklineData: [],\n                isLoading: false,\n            });\n        }\n    };\n\n    const fetchRevenue = async (params: Record<string, string>) => {\n        try {\n            updateMetric(1, { isLoading: true });\n            const res = await api<GenericMetricResponse>(\"/dashboard/revenue\", {\n                method: \"GET\",\n                params,\n            });\n            const val = res.data?.currentValue ?? 0;\n            const pct = res.data?.percentageChange ?? 0;\n            updateMetric(1, {\n                title: \"Revenue\",\n                value: `$${Number(val).toLocaleString()}`,\n                change: `${pct >= 0 ? \"+\" : \"\"}${pct}%`,\n                isPositive: pct >= 0,\n                sparklineData: res.data.sparklineData,\n                isLoading: false,\n            });\n        } catch (error) {\n            console.error(\"Failed to fetch revenue:\", error);\n            updateMetric(1, { value: \"N/A\", change: \"0%\", isPositive: false, isLoading: false });\n        }\n    };\n\n    const fetchActiveSessions = async (params: Record<string, string>) => {\n        try {\n            updateMetric(2, { isLoading: true });\n            const res = await api<GenericMetricResponse>(\"/dashboard/active-sessions\", {\n                method: \"GET\",\n                params,\n            });\n            const val = res.data?.currentValue ?? 0;\n            const pct = res.data?.percentageChange ?? 0;\n            updateMetric(2, {\n                title: \"Active User Sessions\",\n                value: Number(val).toLocaleString(),\n                change: `${pct >= 0 ? \"+\" : \"\"}${pct}%`,\n                isPositive: pct >= 0,\n                sparklineData: res.data.sparklineData,\n                isLoading: false,\n            });\n        } catch (error) {\n            console.error(\"Failed to fetch active sessions:\", error);\n            updateMetric(2, { value: \"N/A\", change: \"0%\", isPositive: false, isLoading: false });\n        }\n    };\n\n    const fetchAiMetrics = async (params: Record<string, string>) => {\n        try {\n            updateMetric(3, { isLoading: true });\n            const res = await api<GenericMetricResponse>(\"/dashboard/ai-tokens\", {\n                method: \"GET\",\n                params,\n            });\n            const val = res.data?.currentValue ?? 0;\n            const pct = res.data?.percentageChange ?? 0;\n            updateMetric(3, {\n                title: \"Avg. AI Model Tokens/Sec\",\n                value: Number(val).toLocaleString(),\n                change: `${pct >= 0 ? \"+\" : \"\"}${pct}%`,\n                isPositive: pct >= 0,\n                sparklineData: res.data.sparklineData,\n                isLoading: false,\n            });\n        } catch (error) {\n            console.error(\"Failed to fetch AI metrics:\", error);\n            updateMetric(3, { value: \"N/A\", change: \"0%\", isPositive: false, isLoading: false });\n        }\n    };\n\n    const fetchAllMetrics = useCallback(() => {\n        // Build the search params from the filters argument\n        const queryParams: Record<string, string> = {};\n        if (filters.dateRange) queryParams.dateRange = filters.dateRange;\n        if (filters.subType) queryParams.subType = filters.subType;\n        if (filters.agencyStatus) queryParams.agencyagencyStatus = filters.agencyStatus;\n\n        // Fire all API requests in parallel. They will resolve and update the UI independently.\n        fetchAgencies(queryParams);\n        fetchRevenue(queryParams);\n        fetchActiveSessions(queryParams);\n        fetchAiMetrics(queryParams);\n    }, [filters.dateRange, filters.subType, filters.agencyStatus, updateMetric]);\n\n    useEffect(() => {\n        fetchAllMetrics();\n    }, [fetchAllMetrics]);\n\n    // Derived global loading state: true if at least one card is still loading\n    const loading = dashboardMetrics.some((metric) => metric.isLoading);\n\n    return {\n        loading,\n        dashboardMetrics,\n        refetch: fetchAllMetrics,\n    };\n}\n"
